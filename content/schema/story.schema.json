{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://littlemandarin.classics/schemas/story.schema.json",
  "title": "Story",
  "description": "小小中文经典 单篇故事数据契约。正文(所有 paragraphs.text 合计)应为 300-600 个汉字；answer 必须等于 options 中之一(由 validator 额外校验)。",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title_zh", "title_en", "level", "age_range", "source_note", "paragraphs", "vocab", "questions", "retell_prompt"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$", "description": "kebab-case 唯一标识，如 peach-garden-oath" },
    "title_zh": { "type": "string", "minLength": 1 },
    "title_en": { "type": "string", "minLength": 1 },
    "level": { "type": "integer", "minimum": 1, "maximum": 3, "description": "难度分级 1-3" },
    "age_range": { "type": "string", "pattern": "^[0-9]+-[0-9]+$", "examples": ["5-6", "7-8", "5-8"] },
    "source_note": { "type": "string", "description": "出处说明，例：Based on public-domain 《三国演义》, rewritten for children." },
    "source_url": { "type": "string", "description": "公有领域底本链接(可选)" },
    "cover_image": { "type": "string", "description": "封面资源相对路径(可选)" },
    "paragraphs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "pinyin", "cells"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "pinyin": { "type": "string", "minLength": 1, "description": "整段拼音，多音字按语境" },
          "cells": {
            "type": "array",
            "description": "与 text Unicode 字符一一对应的逐字拼音；汉字 p 非空，非汉字 p 为空字符串。",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["c", "p"],
              "properties": {
                "c": { "type": "string", "minLength": 1, "maxLength": 1 },
                "p": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "vocab": {
      "type": "array",
      "minItems": 5,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["word", "pinyin", "meaning"],
        "properties": {
          "word": { "type": "string", "minLength": 1 },
          "pinyin": { "type": "string", "minLength": 1 },
          "meaning": { "type": "string", "minLength": 1, "description": "英文释义" },
          "example": { "type": "string", "description": "例句(可选)" }
        }
      }
    },
    "questions": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "prompt", "options", "answer", "explanation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["single_choice"] },
          "prompt": { "type": "string", "minLength": 1 },
          "options": { "type": "array", "minItems": 2, "maxItems": 4, "items": { "type": "string", "minLength": 1 } },
          "answer": { "type": "string", "minLength": 1, "description": "必须等于 options 中之一" },
          "explanation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "retell_prompt": { "type": "string", "minLength": 1 }
  }
}
