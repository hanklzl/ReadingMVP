    "ai_console_retention": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The AI only gives controlled explanations about the current story — no open chat. This log lives on this device, keeps the most recent 200 explanations, and a grown-up can delete it any time. It stores story words and short answer previews only — never your child's name or personal details."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 只围绕当前故事做受控讲解，不做开放聊天。此记录仅保存在本机，最多保留最近 200 条，家长可随时删除。只记录故事中的字词与简短答案预览，绝不记录孩子的姓名或个人信息。"
          }
        }
      }
    },
