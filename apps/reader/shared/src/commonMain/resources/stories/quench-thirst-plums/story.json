  "id": "quench-thirst-plums",
  "title_zh": "望梅止渴",
  "title_en": "Quenching Thirst with Plums",
  "level": 1,
  "age_range": "5-8",
  "source_note": "Based on public-domain 《世说新语·假谲》 Cao Cao anecdote, rewritten for children.",
