*.m4a  filter=lfs diff=lfs merge=lfs -text
*.ogg  filter=lfs diff=lfs merge=lfs -text
*.aac  filter=lfs diff=lfs merge=lfs -text
content/stories/**/*.png  filter=lfs diff=lfs merge=lfs -text
content/stories/**/*.jpg  filter=lfs diff=lfs merge=lfs -text
content/stories/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
